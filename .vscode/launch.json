{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Debug SvelteKit (Server-side)",
			"type": "node",
			"request": "launch",
			"runtimeExecutable": "npm",
			"runtimeArgs": ["run", "dev"],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"skipFiles": ["<node_internals>/**"],
			"env": {
				"NODE_OPTIONS": "--enable-source-maps"
			}
		},
		{
			"name": "Debug SvelteKit (Browser)",
			"type": "chrome",
			"request": "launch",
			"url": "http://localhost:5173",
			"webRoot": "${workspaceFolder}/src"
		}
	]
}
