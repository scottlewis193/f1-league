{
	"name": "f1-league",
	"version": "0.0.1",
	"devDependencies": {
		"@catppuccin/daisyui": "^2.1.1",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-node": "^5.5.3",
		"@sveltejs/kit": "^2.52.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.0",
		"@types/node": "^24.10.13",
		"@types/web-push": "^3.6.4",
		"daisyui": "^5.5.18",
		"eslint": "^10.5.0",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^16.5.0",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.5.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.53.0",
		"svelte-check": "^4.4.1",
		"svelte-confetti": "^2.3.2",
		"tailwindcss": "^4.2.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.61.0",
		"vite": "^7.3.1",
		"vite-plugin-pwa": "^1.3.0",
		"vitest": "^4.1.9",
		"workbox-core": "^7.4.0",
		"workbox-precaching": "^7.4.0"
	},
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"test": "vitest run",
		"validate": "npm run check && npm run lint && npm run test && npm run build",
		"format": "prettier --write .",
		"copy": "scp -r ./package.json ./bun.lockb ./svelte.config.js ./build root@192.168.0.2:/mnt/cache/appdata/f1-league",
		"start": "bun install && bunx puppeteer browsers install chrome && export PORT=9173 && bun build/index.js"
	},
	"type": "module",
	"dependencies": {
		"pocketbase": "^0.27.0",
		"puppeteer": "^24.37.5",
		"puppeteer-extra": "^3.3.6",
		"puppeteer-extra-plugin-stealth": "^2.11.2",
		"valibot": "^1.2.0",
		"web-push": "^3.6.7"
	}
}
